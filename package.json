{
  "name": "embedblocks-studio",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "description": "Visual Embedded Programming Studio",
  "author": "EmbedBlocks",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/utils/cleanup.js && node scripts/utils/sync_blockly_media.js",
    "build": "node scripts/utils/sync_blockly_media.js && npm run clean:build && tsc && vite build && vite build -c vite.sandbox.config.js",
    "start": "npm run build && electron .",
    "release": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps",
    "preview": "vite preview",
    "clean:build": "rimraf dist dist-electron",
    "clean:all": "rimraf node_modules dist dist-electron release package-lock.json",
    "clean:pio": "rimraf bundled_pio",
    "gen:stm32": "npx tsx scripts/core/7_parse_stm32duino_variants.ts && npx tsx scripts/core/1c_discover_from_open_data.ts && npx tsx scripts/core/2_scan_stm32_pins.ts && npx tsx scripts/core/5_fetch_official_layouts.ts && npx tsx scripts/core/4_generate_stm32_data.ts",
    "sync:stm32": "npx tsx scripts/ops/global_sync_data.ts",
    "bundle:core": "npx tsx scripts/ops/bundle_resources.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:build": "vite build -c vite.config.js -m production",
    "test:generate": "electron . --generate-test-projects",
    "test:compile": "electron . --compile-test-projects",
    "test:clean": "electron . --clean-test-projects",
    "test:board": "npx electron . --run-board-tests --board="
  },
  "dependencies": {
    "@blockly/block-plus-minus": "^9.0.5",
    "@blockly/field-angle": "^6.0.5",
    "@blockly/field-multilineinput": "^6.0.5",
    "@blockly/field-slider": "^8.0.5",
    "@blockly/plugin-cross-tab-copy-paste": "^8.0.4",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.3.0",
    "blockly": "^12.3.1",
    "dompurify": "^3.3.2",
    "glob": "^13.0.0",
    "i18next": "^25.7.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "iconv-lite": "^0.7.1",
    "lucide-react": "^0.344.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.3.5",
    "react-jss": "^10.10.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.19.27",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/serialport": "^8.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "jimp": "^1.6.0",
    "jsdom": "^28.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.35",
    "rimraf": "^5.0.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^1.6.1"
  },
  "build": {
    "appId": "com.embedblocks.studio",
    "productName": "EmbedBlocks Studio",
    "directories": {
      "output": "release"
    },
    "fileAssociations": [
      {
        "ext": "ebproj",
        "name": "EmbedBlocks Project",
        "role": "Editor",
        "icon": "icon.ico"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bundled_pio",
        "to": "bundled_pio",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EmbedBlocks Studio"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
